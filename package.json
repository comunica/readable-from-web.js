{
  "name": "readable-from-web",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "yarn@4.12.0",
  "description": "Experimental converter from WHATWG ReadableStream to readable-stream Readable",
  "license": "MIT",
  "homepage": "https://github.com/comunica/readable-from-web.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/comunica/readable-from-web.js.git"
  },
  "bugs": {
    "url": "https://github.com/comunica/readable-from-web/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "types": "lib/index",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "build": "vite build",
    "test": "vitest run --project node"
  },
  "dependencies": {
    "@types/readable-stream": "^4.0.0",
    "readable-stream": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^10.0.0",
    "jiti": "^2.0.0",
    "playwright": "^1.0.0",
    "readable-stream-node-to-web": "^1.0.0",
    "stream-to-string": "^1.0.0",
    "streamify-string": "^1.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "*",
    "vitest": "^4.0.0"
  },
  "resolutions": {
    "rolldown": "^1.0.0-rc.7",
    "vite": "^8.0.0-beta.16"
  }
}
